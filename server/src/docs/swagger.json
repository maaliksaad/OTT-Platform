    "/subscriptions/plan": {
      "post": {
        "tags": ["Subscriptions"],
        "summary": "Activate paid subscription plan",
        "description": "Subscribe to a paid plan (Basic, Standard, or Premium). Valid credit card information is required for payment processing.",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["planId", "period", "cardDetails"],
                "properties": {
                  "planId": { 
                    "type": "string", 
                    "enum": ["basic", "standard", "premium"], 
                    "example": "basic",
                    "description": "Subscription plan type"
                  },
                  "period": { 
                    "type": "string", 
                    "enum": ["month", "year"], 
                    "example": "month",
                    "description": "Billing period - monthly or yearly"
                  },
                  "cardDetails": { "$ref": "#/components/schemas/CardDetails" }
                }
              },
              "examples": {
                "basicMonthly": {
                  "summary": "Basic plan - Monthly billing",
                  "value": {
                    "planId": "basic",
                    "period": "month",
                    "cardDetails": {
                      "cardNumber": "4111111111111111",
                      "expiryDate": "12/25",
                      "cvv": "123",
                      "cardholderName": "John Doe"
                    }
                  }
                },
                "premiumYearly": {
                  "summary": "Premium plan - Yearly billing (20% discount)",
                  "value": {
                    "planId": "premium",
                    "period": "year",
                    "cardDetails": {
                      "cardNumber": "5555555555554444",
                      "expiryDate": "08/26",
                      "cvv": "456",
                      "cardholderName": "Jane Smith"
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Paid subscription activated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean", "example": true },
                    "message": { "type": "string", "example": "Basic plan activated successfully" },
                    "data": { "$ref": "#/components/schemas/Subscription" }
                  }
                }
              }
            }
          },
          "400": { 
            "description": "Invalid plan data or user already has active subscription",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "401": { 
            "description": "Unauthorized - Login required",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "402": { 
            "description": "Payment failed - Invalid credit card or insufficient funds",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "422": { 
            "description": "Validation failed - Invalid input data",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      }
    },
